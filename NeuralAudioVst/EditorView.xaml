<UserControl x:Class="NeuralAudioVst.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:AudioPlugSharpWPF="clr-namespace:AudioPlugSharpWPF;assembly=AudioPlugSharpWPF"
             xmlns:local="clr-namespace:NeuralAudioVst"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300">
    <DockPanel Width="300" Height="150">
        <Button DockPanel.Dock="Bottom" Content="Load Model" Click="LoadButton_Click" />
        <AudioPlugSharpWPF:ParameterDisplay HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </DockPanel>
</UserControl>
